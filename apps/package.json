{
  "name": "portfolio",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "content:build": "node scripts/build-content.mjs",
    "dev": "npm run content:build && next dev -p 3043 --turbopack",
    "build": "npm run content:build && next build",
    "start": "next start",
    "lint": "next lint",
    "magic": "node scripts/magic.mjs",
    "preview": "npm run content:build && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "npm run content:build && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "npm run content:build && opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.3",
    "@supabase/supabase-js": "^2.97.0",
    "clsx": "^2.1.1",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "^10.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-highlight": "^7.0.2",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "tailwind-merge": "^3.5.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.14",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.14.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "wrangler": "^4.77.0"
  }
}
